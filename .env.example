# ==============================================================================
# Gemini Job Automation Agent - Environment Variables Template
# Copy this file to '.env' and fill in your details securely.
# ==============================================================================

# Gemini API Credentials
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash # Recommended model for fast, multi-modal web agentic tasks

# Browser/Sandbox Configuration
HEADLESS=true
BROWSER_TIMEOUT_MS=30000
USER_DATA_DIR=./.browser_session # Directory to persist cookies & session state

# Portal Cookies / Session Injection (Optional - if login bypass is desired)
LINKEDIN_SESSION_COOKIE=AQEDAR...
INDEED_SESSION_COOKIE=...
GLASSDOOR_SESSION_COOKIE=...

# Monitoring & Logs
LOG_LEVEL=INFO
CHECKPOINT_OUTPUT_DIR=./workflows/checkpoints
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/... # Optional: for notifications
